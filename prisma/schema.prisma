generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id                 String   @id @default(cuid())
  name               String
  shortName          String?
  legalType          String
  taxId              String?  @unique
  status             String   @default("draft")
  shortDescription   String?
  legalAddress       String?
  businessAddress    String?
  tenantDatabaseName String?

  serviceStatus     String    @default("servicing")
  serviceStoppedAt  DateTime?
  serviceStopReason String?
  archivedAt        DateTime?

  registryCheckStatus String    @default("not_checked")
  registryCheckedAt    DateTime?
  registryCheckedBy    String?
  registryName         String?
  registryTaxId        String?
  registryLegalAddress String?
  registryStatus       String?
  registrySource       String?
  registryNotes        String?

  contracts ServiceContract[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}


model ServiceContract {
  id                String   @id @default(cuid())
  organizationId    String
  organization      Organization @relation(fields: [organizationId], references: [id])

  contractNumber    String
  signedAt          String?
  startsAt          String?
  endsAt            String?

  employeeCount        Int?
  monthlyDocumentCount Int?
  taxRegime            String?
  bankAccountCount     Int?
  hasVat               Boolean @default(false)
  hasWarehouse         Boolean @default(false)
  hasProduction        Boolean @default(false)
  hasImportExport      Boolean @default(false)
  suggestedFeeAmount   String?
  approvedFeeAmount    String?
  feeAmount         String?
  feeCurrency       String   @default("AMD")
  status            String   @default("draft")
  responsiblePerson String?
  notes             String?

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([organizationId])
}
