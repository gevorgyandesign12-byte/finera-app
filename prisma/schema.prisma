generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id                      String    @id @default(cuid())
  name                    String
  shortName               String?
  legalType               String
  taxId                   String?   @unique
  serviceCode             String?   @unique
  status                  String    @default("draft")
  shortDescription        String?
  legalAddress            String?
  businessAddress         String?
  tenantDatabaseName      String?
  tenantDatabaseStatus    String    @default("planned")
  tenantDatabaseCreatedAt DateTime?
  tenantDatabaseError     String?
  organizationKind        String    @default("serviced_partner")

  serviceStatus     String    @default("servicing")
  serviceStoppedAt  DateTime?
  serviceStopReason String?
  archivedAt        DateTime?

  registryCheckStatus   String    @default("not_checked")
  registryCheckedAt     DateTime?
  registryCheckedBy     String?
  registryName          String?
  registryTaxId         String?
  registryLegalAddress  String?
  registryStatus        String?
  registrySource        String?
  registryNotes         String?
  stateRegistrationDate String?

  contracts               ServiceContract[]
  organizationEmployees   OrganizationEmployee[]
  serviceAssignments      ServiceAssignment[]
  representatives         OrganizationRepresentative[]
  businessAddresses       OrganizationBusinessAddress[]
  subdivisions            OrganizationSubdivision[]
  subdivisionResponsibles OrganizationSubdivisionResponsible[]

  postalCode String?
  activities OrganizationActivity[]
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
}

model OrganizationRepresentative {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  fullName           String
  roleTitle          String
  representativeType String  @default("legal_head")
  employeeId         String?
  isCurrent          Boolean @default(true)
  startsAt           String?
  endsAt             String?
  authorityBasis     String?
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([employeeId])
  @@index([representativeType])
}

model OrganizationBusinessAddress {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  code      String  @unique
  address   String
  isPrimary Boolean @default(false)
  status    String  @default("active")
  notes     String?

  subdivisions OrganizationSubdivision[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
}

model OrganizationSubdivision {
  id                String                      @id @default(cuid())
  organizationId    String
  organization      Organization                @relation(fields: [organizationId], references: [id])
  businessAddressId String
  businessAddress   OrganizationBusinessAddress @relation(fields: [businessAddressId], references: [id])

  code   String  @unique
  name   String
  type   String  @default("other")
  status String  @default("active")
  notes  String?

  capabilityMaterialsFixedAssets Boolean @default(true)
  capabilityCashBank             Boolean @default(false)
  capabilitySalesHdm             Boolean @default(false)
  capabilityWarehouse            Boolean @default(false)
  capabilityProduction           Boolean @default(false)

  responsibles OrganizationSubdivisionResponsible[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([businessAddressId])
  @@index([type])
  @@index([status])
}

model OrganizationSubdivisionResponsible {
  id             String                  @id @default(cuid())
  organizationId String
  organization   Organization            @relation(fields: [organizationId], references: [id])
  subdivisionId  String
  subdivision    OrganizationSubdivision @relation(fields: [subdivisionId], references: [id])

  employeeId         String?
  employeeFullName   String
  employeePosition   String?
  responsibilityRole String
  isPrimary          Boolean @default(true)
  startsAt           String?
  endsAt             String?
  status             String  @default("active")
  notes              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([subdivisionId])
  @@index([employeeId])
  @@index([responsibilityRole])
}

model ServiceContract {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  contractNumber String
  signedAt       String?
  startsAt       String?
  endsAt         String?

  employeeCount        Int?
  monthlyDocumentCount Int?
  taxRegime            String?
  bankAccountCount     Int?
  hasVat               Boolean @default(false)
  hasWarehouse         Boolean @default(false)
  hasProduction        Boolean @default(false)
  hasImportExport      Boolean @default(false)
  suggestedFeeAmount   String?
  approvedFeeAmount    String?
  feeAmount            String?
  feeCurrency          String  @default("AMD")
  status               String  @default("draft")
  responsiblePerson    String?
  notes                String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model FineraEmployee {
  id                 String                     @id @default(cuid())
  fullName           String
  email              String?                    @unique
  phone              String?
  roleGroup          String
  positionTitle      String
  departmentName     String
  employmentType     String                     @default("full_time")
  employmentStatus   String                     @default("active")
  hireDate           String
  notes              String?
  serviceAssignments ServiceAssignment[]
  capabilities       FineraEmployeeCapability[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceAssignment {
  id String @id @default(cuid())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  fineraEmployeeId String
  fineraEmployee   FineraEmployee @relation(fields: [fineraEmployeeId], references: [id])

  roleScope  String
  workScope  String
  status     String    @default("active")
  assignedAt DateTime  @default(now())
  endedAt    DateTime?
  notes      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, fineraEmployeeId, roleScope, workScope])
  @@index([organizationId])
  @@index([fineraEmployeeId])
  @@index([roleScope])
}

model FineraEmployeeCapability {
  id               String         @id @default(cuid())
  fineraEmployeeId String
  fineraEmployee   FineraEmployee @relation(fields: [fineraEmployeeId], references: [id])
  capabilityScope  String
  status           String         @default("active")
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fineraEmployeeId, capabilityScope])
  @@index([capabilityScope])
  @@index([status])
}

model OrganizationEmployee {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  fullName         String
  taxId            String?
  phone            String?
  email            String?
  positionTitle    String
  departmentName   String?
  employmentType   String  @default("full_time")
  employmentStatus String  @default("active")
  hireDate         String
  salaryAmount     String?
  notes            String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model Position {
  id             String  @id @default(cuid())
  title          String
  scope          String  @default("finera")
  organizationId String?
  departmentName String?
  status         String  @default("active")
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope])
  @@index([organizationId])
}

model Department {
  id             String  @id @default(cuid())
  name           String
  scope          String  @default("finera")
  organizationId String?
  status         String  @default("active")
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scope])
  @@index([organizationId])
}

model OrganizationActivity {
  id             String       @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  title     String
  code      String?
  isPrimary Boolean @default(false)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model Currency {
  id           String @id @default(cuid())
  isoCode      String @unique
  numericCode  String?
  name         String
  armenianName String?
  englishName  String?
  nominal      Int    @default(1)
  isBase       Boolean @default(false)
  isActive     Boolean @default(true)
  source       String @default("CBA")

  exchangeRates ExchangeRate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([source])
}

model ExchangeRate {
  id         String   @id @default(cuid())
  currencyId String
  currency   Currency @relation(fields: [currencyId], references: [id])

  rateDate String
  rate     String
  change   String?

  source            String   @default("CBA")
  sourcePublishedAt String?
  sourceFetchedAt   DateTime @default(now())
  rawPayloadHash    String?
  rawPayload        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([currencyId, rateDate, source])
  @@index([rateDate])
  @@index([source])
  @@index([sourceFetchedAt])
}

model ExchangeRateFetchLog {
  id String @id @default(cuid())

  source        String   @default("CBA")
  fetchType     String   @default("daily")
  requestedDate String?
  status        String
  ratesCount    Int      @default(0)
  errorMessage  String?
  rawPayloadHash String?

  fetchedAt   DateTime @default(now())
  completedAt DateTime?

  @@index([source])
  @@index([status])
  @@index([requestedDate])
  @@index([fetchedAt])
}

model ArmenianBank {
  id String @id @default(cuid())

  bankCode      String  @unique
  swiftCode     String?
  name          String
  legalName     String?
  shortName     String?

  directoryType  String  @default("bank")
  parentBankCode String?
  isHeadOffice   Boolean @default(false)
  isBranch       Boolean @default(false)
  taxId         String?
  licenseNumber String?
  licenseDate   String?

  headName String?
  address  String?
  phone    String?
  email    String?
  website  String?

  status   String  @default("active")
  isActive Boolean @default(true)

  source          String   @default("CBA")
  sourceUrl       String?
  sourceFetchedAt DateTime?
  rawPayloadHash  String?
  rawPayload      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([swiftCode])
  @@index([parentBankCode])
  @@index([directoryType])
  @@index([isHeadOffice])
  @@index([isBranch])
  @@index([taxId])
  @@index([status])
  @@index([isActive])
  @@index([source])
  @@index([sourceFetchedAt])
}

model ImportSession {
  id String @id @default(cuid())

  importType   String
  fileName     String
  fileMimeType String?
  fileSize     Int?
  status       String  @default("draft")

  totalRows Int @default(0)
  validRows Int @default(0)
  errorRows Int @default(0)

  createdBy String?
  notes     String?

  createdAt   DateTime  @default(now())
  validatedAt DateTime?
  importedAt  DateTime?

  rows   ImportRow[]
  errors ImportError[]

  @@index([importType])
  @@index([status])
  @@index([createdBy])
  @@index([createdAt])
}

model ImportRow {
  id String @id @default(cuid())

  sessionId String
  session   ImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  rowNumber Int
  status    String @default("draft")

  rawPayload        String
  normalizedPayload String?
  targetKey         String?

  createdAt DateTime @default(now())

  errors ImportError[]

  @@index([sessionId])
  @@index([rowNumber])
  @@index([status])
  @@index([targetKey])
  @@unique([sessionId, rowNumber])
}

model ImportError {
  id String @id @default(cuid())

  sessionId String
  session   ImportSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  rowId String?
  row   ImportRow? @relation(fields: [rowId], references: [id], onDelete: Cascade)

  rowNumber Int?
  fieldName String?
  errorCode String
  message   String
  severity  String @default("error")

  createdAt DateTime @default(now())

  @@index([sessionId])
  @@index([rowId])
  @@index([rowNumber])
  @@index([fieldName])
  @@index([errorCode])
  @@index([severity])
}
